# Neon Postgres connection string (use pooled URL for serverless/Vercel)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Email for employee "Request my records" (use ONE option below)

# Option A — Resend (recommended on Vercel; avoids SMTP timeouts from cloud hosts)
# RESEND_API_KEY=re_xxxxxxxx
# SMTP_FROM=AttendanceHub <noreply@yourdomain.com>

# Option B — SMTP (works locally; many shared hosts block Vercel outbound SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AttendanceHub <noreply@example.com>
